# ───────── 외부 데이터 API ─────────
# Finnhub — 주가·뉴스·경제 캘린더 (https://finnhub.io/ 무료 tier)
FINNHUB_API_KEY=

# FRED — 매크로 지표 (10Y, DXY, WTI). https://fredaccount.stlouisfed.org/apikeys
FRED_API_KEY=

# ───────── AI ─────────
# Anthropic Claude (https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=

# Voyage AI — RAG 뉴스 임베딩 (voyage-3, 1024차원). https://dash.voyageai.com/
VOYAGE_API_KEY=

# ───────── Supabase (배치 결과 저장소) ─────────
# 프로젝트 Settings → API 에서 확인
SUPABASE_URL=
# ⚠ service_role 키 (anon 아님). 서버 전용.
SUPABASE_SERVICE_ROLE_KEY=

# ───────── 인증 ─────────
# Cloud Scheduler / 외부 cron이 /api/cron/briefing 호출 시 사용하는 Bearer 토큰 (openssl rand -hex 32)
CRON_SECRET=
# /admin/* 경로 Basic Auth 비밀번호 (사용자명은 아무거나)
ADMIN_PASSWORD=
